{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Module2Output",
  "type": "object",
  "required": ["request_id","document_id","module","version","timestamp","status","payload"],
  "properties": {
    "request_id": { "type": "string" },
    "document_id": { "type": "string" },
    "module": { "type": "string" },
    "version": { "type": "string" },
    "timestamp": { "type": "string" },
    "status": { "type": "string", "enum": ["success", "error"] },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" }
      },
      "required": ["code", "message"]
    },
    "payload": {
      "type": "object",
      "required": ["page","input_image","engine","language","text","blocks"],
      "properties": {
        "page": { "type": "integer" },
        "input_image": { "type": "string" },
        "engine": { "type": "string" },
        "language": { "type": "string" },
        "text": { "type": "string" },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["level","text","bbox","confidence"],
            "properties": {
              "level": { "type": "string", "enum": ["block","line","word"] },
              "text": { "type": "string" },
              "bbox": {
                "type": ["array","null"],
                "items": { "type": "integer" },
                "minItems": 4,
                "maxItems": 4
              },
              "confidence": { "type": ["number","null"] }
            }
          }
        },
        "meta": { "type": ["object","null"] }
      }
    }
  }
}
